# Nexus Studio — copy to .env and fill in values
# Backend (node) reads from repo root and nexus-studio-app; frontend uses VITE_* only.

# Server
PORT=8765

# Gemini (required for image/video generation, prompts, analyze-market)
GEMINI_API_KEY=
# Or multiple keys (comma-separated) for quota rotation:
# GEMINI_API_KEYS=key1,key2

# Storage (optional; default is backend/storage)
# STORAGE_DIR=./backend/storage

# Track Adobe proxy (optional; for /api/track-adobe search)
# TRACK_ADOBE_COOKIES=...
# Or:
# TRACK_ADOBE_SESSION_TOKEN=...
# TRACK_ADOBE_CSRF_TOKEN=...

# Frontend (optional): backend base URL when not using same-origin
# Leave empty in dev (Vite proxy) or when served by backend. Set for standalone frontend.
# VITE_API_URL=http://localhost:8765
